# Google Sheets API Key (create at console.cloud.google.com → Credentials → API Key)
GOOGLE_API_KEY=your_api_key_here

# Spreadsheet ID from the URL: /spreadsheets/d/{ID}/edit
GOOGLE_SHEETS_SPREADSHEET_ID=16ZzbhpEpOUj0prKrN06qlY-aS-c9mW1CgLKbFWm-bvM

# Sheet tab names (change if your tabs have different names)
SHEET_DESAFIO1=DESAFIO 1
SHEET_DESAFIO2=DESAFIO 2

# Cache & Refresh (hours)
CACHE_TTL_HOURS=12
REFRESH_INTERVAL_HOURS=12

# App
NEXT_PUBLIC_API_URL=http://localhost:3000
NODE_ENV=development
